49|      "slug": "how-to-check-aadhaar-status-online",
50|      "title": "How to Check Aadhaar Status Online – Step by Step Guide 2026",
51|      "category": "aadhaar",
52|      "description": "Check your Aadhaar enrollment or update status online at uidai.gov.in. Complete step-by-step guide with screenshots for 2026.",
53|      "date": "2026-06-09",
54|      "readTime": "4 min",
55|      "content": [
56|        {
57|          "type": "p",
58|          "text": "Applied for a new Aadhaar card or requested an update? Knowing how to check your Aadhaar status online saves you from unnecessary trips to the enrollment center. This guide covers every method to check Aadhaar status in 2026."
59|        },
60|        {
61|          "type": "h2",
62|          "text": "What is Aadhaar Status?"
63|        },
64|        {
65|          "type": "p",
66|          "text": "Aadhaar status tells you whether your enrollment or update request has been processed by UIDAI. Common statuses include:"
67|        },
68|        {
69|          "type": "ul",
70|          "items": [
71|            "Under Process — Your application is being verified",
72|            "Generated — Aadhaar has been issued (download available)",
73|            "Sent for Printing — Aadhaar letter is being printed",
74|            "Dispatched — Physical letter has been sent via India Post",
75|            "Rejected — Issue with documents or biometrics"
76|          ]
77|        },
78|        {
79|          "type": "h2",
80|          "text": "Method 1: Check Aadhaar Status on UIDAI Website"
81|        },
82|        {
83|          "type": "step",
84|          "title": "Step 1: Visit the UIDAI Website",
85|          "text": "Go to https://uidai.gov.in. This is the official UIDAI portal. Look for the 'Check Aadhaar Status' option under the 'My Aadhaar' section."
86|        },
87|        {
88|          "type": "step",
89|          "title": "Step 2: Enter Your Enrollment ID (EID)",
90|          "text": "Your Enrollment ID is a 14-digit number printed on the acknowledgement slip you received during enrollment. It usually looks like 1234/56789/12345."
91|        },
92|        {
93|          "type": "step",
94|          "title": "Step 3: Enter Date and Time",
95|          "text": "Enter the date and time shown on your acknowledgement slip. This helps UIDAI verify your application."
96|        },
97|        {
98|          "type": "step",
99|          "title": "Step 4: Enter Captcha and Submit",
100|          "text": "Type the captcha code shown on screen and click 'Check Status'. Your current Aadhaar status will be displayed."
101|        },
102|        {
103|          "type": "tip",
104|          "text": "Keep your acknowledgement slip safe — it contains the Enrollment ID and date/time needed to check status. Take a photo of it on your phone."
105|        },
106|        {
107|          "type": "h2",
108|          "text": "Method 2: Check via mAadhaar App"
109|        },
110|        {
111|          "type": "p",
112|          "text": "The official mAadhaar app (available on Google Play Store) lets you check Aadhaar status on your phone. Download the app, register with your mobile number, and use the 'Check Status' feature. No EID needed if you're already registered."
113|        },
114|        {
115|          "type": "h2",
116|          "text": "Method 3: Check via SMS (Offline)"
117|        },
118|        {
119|          "type": "p",
120|          "text": "Send an SMS in this format to 51969 or 166 (or the number specified by UIDAI for your circle):"
121|        },
122|        {
123|          "type": "code",
124|          "text": "UIDSTATUS <14-digit Enrollment ID>"
125|        },
126|        {
127|          "type": "p",
128|          "text": "You'll receive an SMS with your current Aadhaar status. Standard SMS charges apply."
129|        },
130|        {
131|          "type": "h2",
132|          "text": "What to Do If Aadhaar Status Shows Rejected?"
133|        },
134|        {
135|          "type": "p",
136|          "text": "If your status shows 'Rejected', don't panic. Common reasons include unclear photographs, mismatched biometrics, or incomplete documents. Visit the nearest Aadhaar enrollment center with correct documents and re-enroll. There is no fee for re-enrollment."
137|        },
138|        {
139|          "type": "h2",
140|          "text": "How Long Does Aadhaar Take?"
141|        },
142|        {
143|          "type": "p",
144|          "text": "Aadhaar typically takes 60-90 days from enrollment to generation. Update requests (address change, mobile update) usually process faster — around 2-3 weeks. During peak periods it may take longer."
145|        },
146|        {
147|          "type": "table",
148|          "headers": [
149|            "Status",
150|            "What It Means",
151|            "Action Needed"
152|          ],
153|          "rows": [
154|            [
155|              "Under Process",
156|              "Verification in progress",
157|              "Wait 2-3 more weeks"
158|            ],
159|            [
160|              "Generated",
161|              "Aadhaar issued",
162|              "Download e-Aadhaar now"
163|            ],
164|            [
165|              "Sent for Printing",
166|              "Card being printed",
167|              "No action needed"
168|            ],
169|            [
170|              "Dispatched",
171|              "Letter sent via post",
172|              "Track on India Post"
173|            ],
174|            [
175|              "Rejected",
176|              "Documents/biometrics failed",
177|              "Visit enrollment center"
178|            ]
179|          ]
180|        },
181|        {
182|          "type": "h2",
183|          "text": "Frequently Asked Questions"
184|        },
185|        {
186|          "type": "h3",
187|          "text": "Can I check Aadhaar status without enrollment ID?"
188|        },
189|        {
190|          "type": "p",
191|          "text": "No, the Enrollment ID (EID) is required to check status on the website. If you lost your acknowledgement slip, visit the enrollment center where you applied — they can provide a duplicate."
192|        },
193|        {
194|          "type": "h3",
195|          "text": "Is the mAadhaar app free?"
196|        },
197|        {
198|          "type": "p",
199|          "text": "Yes, the mAadhaar app is completely free to download and use. It's the official app from UIDAI and works on all Android phones."
200|        }
201|      ]
